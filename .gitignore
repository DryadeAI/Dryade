# Root ignore for Dryade (Python backend + Next.js frontend)

# OS
.DS_Store
Thumbs.db

# Editors/IDEs
.idea/
.vscode/
.vs/
*.swp
*.swo
.history/
*.code-workspace

# Environment files - NEVER commit secrets
.env
.env.*
!.env.example
!.env.quickstart.example
# WARNING: Environment files may contain sensitive data like JWT_SECRET, database passwords, API keys

# Secrets management (SOPS+age)
# - Encrypted files (*.enc) ARE safe to commit — values are encrypted
# - Plaintext secrets MUST NOT be committed
secrets/*.env
secrets/*.key
secrets/*.pem
# Do NOT ignore secrets/*.enc (encrypted, safe to commit)
# Do NOT ignore secrets/keys/ (public keys are safe to commit)

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.pyre/

# Cython build artifacts
*.c
*.so
!scripts/*.c

# Python build/distribution artifacts
build/
dist/
wheels/
*.egg-info/
.eggs/
.tox/
.nox/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/
thor/

# Coverage reports
.coverage
.coverage.*
coverage.xml
htmlcov/

# Logs and databases
*.log
*.sqlite
*.db

# Project runtime data
qdrant_storage/
graphdb/
uploads/

# Node/JS (Next.js app)
node_modules/
.next/
.nuxt/
.turbo/
.parcel-cache/
.eslintcache
out/
.vercel/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Misc backups
*.bak

# MkDocs build output
site/

# Trainer models and data (large binary files)
# Unsloth compiled cache (auto-regenerated at runtime)
unsloth_compiled_cache/


# Local AI assistant config



# Sub-repos are now git submodules — tracked via .gitmodules, NOT ignored
# (removed plugins/, plugin-manager/, marketplace/, dryade-workbench/)
# (removed dryade/ self-reference — makes no sense)

# SQLite WAL/SHM artifacts
*.db-shm
*.db-wal

# Runtime artifacts
coverage.json
trainer/

# Eval production fixtures (environment-specific, regenerated by capture script)
tests/eval/orchestrator/fixtures/production_scenarios.json
tests/eval/orchestrator/results/

.worktrees/
