# ============================================================================
# Dryade Configuration
# ============================================================================
# Copy this file to .env and adjust values for your setup:
#   cp .env.example .env
#
# Then generate a JWT secret:
#   openssl rand -hex 32
#
# And start:
#   docker compose up
# ============================================================================

# --- Database ---------------------------------------------------------------
# PostgreSQL is required. Docker Compose uses this default:
DRYADE_DATABASE_URL=postgresql+psycopg://dryade:dryade@postgres:5432/dryade
# For manual/uv setup (no Docker), use localhost:
# DRYADE_DATABASE_URL=postgresql+psycopg://dryade:your-password@localhost:5432/dryade

# --- Authentication ---------------------------------------------------------
# IMPORTANT: Replace this default before exposing to the network.
# Generate a secure secret: openssl rand -hex 32
DRYADE_JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- LLM Provider -----------------------------------------------------------
# Default: Ollama running on the host machine.
# For Docker: use http://host.docker.internal:11434/v1
# For manual/uv: use http://localhost:11434/v1
DRYADE_LLM_BASE_URL=http://host.docker.internal:11434/v1
DRYADE_LLM_API_KEY=
DRYADE_LLM_MODEL=qwen3:8b

# For OpenAI:
# DRYADE_LLM_BASE_URL=https://api.openai.com/v1
# DRYADE_LLM_API_KEY=sk-your-key-here
# DRYADE_LLM_MODEL=gpt-4o

# For Anthropic:
# DRYADE_LLM_BASE_URL=https://api.anthropic.com/v1
# DRYADE_LLM_API_KEY=sk-ant-your-key-here
# DRYADE_LLM_MODEL=claude-sonnet-4-20250514

# For local vLLM (use with: docker compose --profile gpu up):
# DRYADE_LLM_BASE_URL=http://vllm:8000/v1
# DRYADE_LLM_API_KEY=token-abc123
# DRYADE_LLM_MODEL=local-llm

# --- Server -----------------------------------------------------------------
DRYADE_HOST=0.0.0.0
DRYADE_PORT=8080
DRYADE_LOG_LEVEL=INFO

# --- Frontend ---------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080

# --- Docker Compose ---------------------------------------------------------
# Password for the PostgreSQL container
POSTGRES_PASSWORD=CHANGE_ME

# Port for the frontend container
FRONTEND_PORT=3000

# --- GPU / vLLM (optional) --------------------------------------------------
# Model to serve with vLLM (used with --profile gpu)
VLLM_MODEL=Qwen/Qwen3-8B
