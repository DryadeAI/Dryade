  "edges": [
    {"id": "e1", "source": "start", "target": "intake"},
    {"id": "e2", "source": "intake", "target": "process"},
    {"id": "e3", "source": "process", "target": "resolve"},
    {"id": "e4", "source": "resolve", "target": "followup"},
