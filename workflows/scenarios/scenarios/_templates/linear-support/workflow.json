      },
      "position": {"x": 400, "y": 0}
    },
    {
      "id": "resolve",
      "type": "task",
      "data": {
        "agent": "research_assistant",
        "task": "Finalize and deliver: refine the drafted response and deliver it to the requester",
        "context": {"requires": ["process.output"]}
      },
      "position": {"x": 600, "y": 0}
    },
    {
      "id": "followup",
      "type": "task",
      "data": {
        "agent": "research_assistant",
        "task": "Log and follow up: record the resolution outcome, update ticket status, and schedule follow-up if needed",
        "context": {"requires": ["resolve.output"]}
      },
      "position": {"x": 800, "y": 0}
    },
    {
      "id": "end",
      "type": "end",
      "position": {"x": 1000, "y": 0}
    }
