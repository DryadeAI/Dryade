{
  "version": "1.0.0",
  "metadata": {
    "name": "_templates/linear-support",
    "description": "Canonical 4-task support template: start → intake → process → resolve → followup → end",
    "domain": "support",
    "difficulty": "intermediate"
  },
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": {"x": 0, "y": 0}
    },
    {
      "id": "intake",
      "type": "task",
      "data": {
        "agent": "research_assistant",
        "task": "Receive and classify request: intake the incoming request, identify type and priority, and route appropriately",
        "context": {}
      },
      "position": {"x": 200, "y": 0}
    },
    {
      "id": "process",
      "type": "task",
      "data": {
        "agent": "research_assistant",
        "task": "Research and draft response: look up relevant knowledge, policies, and prior cases to draft a response",
