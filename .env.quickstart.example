# Dryade Quickstart Configuration
# =============================================================================
# This file contains pre-configured settings for the zero-friction quickstart.
#
# Usage:
#   cp .env.quickstart.example .env
#   docker compose -f deploy/docker-compose.quickstart.yml up -d
#
# Everything below is pre-configured. You do NOT need to change anything
# to get started with Dryade using a local Ollama model.
# =============================================================================

# LLM — Ollama (local, no API key needed)
DRYADE_LLM_MODE=ollama
DRYADE_LLM_MODEL=llama3.2:3b
DRYADE_LLM_BASE_URL=http://ollama:11434

# Security (disabled for quickstart — enable for production)
DRYADE_AUTH_ENABLED=false
DRYADE_JWT_SECRET=quickstart-change-me-in-production

# CORS
DRYADE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# --- Cloud Provider Alternative ---
# Want to use OpenAI, Anthropic, or another cloud LLM instead of Ollama?
# Comment out the Ollama settings above and uncomment the lines below.
# =============================================================================
#
# OpenAI:
# DRYADE_LLM_MODE=openai
# DRYADE_LLM_MODEL=gpt-4o
# DRYADE_LLM_BASE_URL=https://api.openai.com/v1
# DRYADE_LLM_API_KEY=sk-your-key-here
#
# Anthropic (via OpenAI-compatible proxy):
# DRYADE_LLM_MODE=openai
# DRYADE_LLM_MODEL=claude-3-5-sonnet-20241022
# DRYADE_LLM_BASE_URL=https://api.anthropic.com/v1
# DRYADE_LLM_API_KEY=sk-ant-your-key-here
#
# Any OpenAI-compatible provider (Azure, Groq, Together, etc.):
# DRYADE_LLM_MODE=openai
# DRYADE_LLM_MODEL=your-model-name
# DRYADE_LLM_BASE_URL=https://your-provider.com/v1
# DRYADE_LLM_API_KEY=your-api-key
