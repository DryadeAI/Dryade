# {{ name | replace('_', ' ') | title | replace(' ', '') }} Agent Configuration
# LangGraph-based agent - factory generated

name: {{ name }}
version: "{{ version | default('1.0.0') }}"
description: "{{ description }}"

# Framework type - LangChain with LangGraph
framework: langchain

# Required MCP servers for operation
mcp_servers:
{% for server in mcp_servers %}
  - {{ server }}
{% endfor %}

# Streaming support
streaming: {{ streaming | default(true) | lower }}

# Agent system prompt
system_prompt: |
  {{ system_prompt | indent(2) }}

# Capabilities exposed by this agent
capabilities:
{% for cap in capabilities | default([]) %}
  - {{ cap }}
{% endfor %}
