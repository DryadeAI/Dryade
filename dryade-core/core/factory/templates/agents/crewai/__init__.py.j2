def _create_crewai_tools() -> list[Any]:
    """Create CrewAI BaseTool subclasses for MCP tools.

    Returns:
        List of CrewAI tool instances.

    Note:
        Returns empty list if crewai is not installed.
    """
    try:
        from crewai.tools import BaseTool
    except ImportError:
        logger.warning("CrewAI not installed - tools will not be available")
        return []

    tools: list[Any] = []

{% for tool in tools %}
    class {{ tool.tool | replace('-', ' ') | replace('_', ' ') | title | replace(' ', '') }}Tool(BaseTool):
        """{{ tool.description }}"""

        name: str = "{{ tool.tool }}"
        description: str = "{{ tool.description }}"

        def _run(self, **kwargs: Any) -> str:
            """Execute the tool."""
            try:
                return _{{ tool.tool | replace('-', '_') }}_wrapper.call(**kwargs)
            except Exception as e:
                logger.warning(f"{{ tool.tool }} error: {e}")
                return f"[Error] {{ tool.tool }} failed: {e}"

    tools.append({{ tool.tool | replace('-', ' ') | replace('_', ' ') | title | replace(' ', '') }}Tool())
{% endfor %}
    return tools


