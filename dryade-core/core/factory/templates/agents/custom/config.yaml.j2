# {{ name }} - Custom MCP-native Agent Configuration
# Auto-generated by Dryade Agent Factory

name: {{ name }}
version: "{{ version | default('1.0.0') }}"
description: "{{ description }}"

# Framework type - MCP native (no external framework)
framework: custom

# Required MCP servers
mcp_servers:
{% for server in mcp_servers %}
  - {{ server }}
{% endfor %}

# Capabilities exposed by this agent
capabilities:
{% for cap in capabilities %}
  - {{ cap }}
{% endfor %}
{% if not capabilities %}
  []
{% endif %}

# Task routing keywords
routing:
{% for tool in tools %}
  {{ tool.tool }}:
    keywords: ["{{ tool.tool | replace('_', ' ') }}", "{{ tool.description | lower }}"]
{% endfor %}

# Default context values
defaults:
  timeout: 30
