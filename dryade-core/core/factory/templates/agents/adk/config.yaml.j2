# {{ name }} - ADK Agent Configuration
# Auto-generated by Dryade Agent Factory

name: {{ name }}
version: "{{ version | default('1.0.0') }}"
description: "{{ description }}"

# Framework type
framework: adk

# LLM model (configurable)
model: "{{ model | default('gemini-2.0-flash') }}"

# Agent instruction
instruction: "{{ instruction }}"

# Required MCP servers
mcp_servers:
{% for server in mcp_servers %}
  - {{ server }}
{% endfor %}

# Capabilities
capabilities:
{% for cap in capabilities %}
  - {{ cap }}
{% endfor %}
{% if not capabilities %}
  []
{% endif %}
